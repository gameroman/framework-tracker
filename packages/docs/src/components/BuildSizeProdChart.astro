---
import { starterStats } from '../lib/collections'
import ComparisonBarChart from './ComparisonBarChart.astro'

const validEntries = starterStats.filter(
  (f) => f?.name != null && Number.isFinite(f.warmBuildTime?.avgMs),
)

const data = validEntries.map((f) => ({
  name: f.name,
  value: f.warmBuildTime.avgMs / 1000,
  focused: f.isFocused,
}))
---

<ComparisonBarChart title="Warm build time" data={data} valueFormat="s" />
