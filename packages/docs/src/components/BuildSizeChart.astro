---
import { starterStats } from '../lib/collections'
import ComparisonBarChart from './ComparisonBarChart.astro'

const validEntries = starterStats.filter(
  (f) => f?.name != null && Number.isFinite(f.coldBuildTime?.avgMs),
)

const data = validEntries.map((f) => ({
  name: f.name,
  value: f.coldBuildTime.avgMs / 1000,
  focused: f.isFocused,
}))
---

<ComparisonBarChart title="Cold build time" data={data} valueFormat="s" />
